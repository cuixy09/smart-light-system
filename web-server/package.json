{
  "name": "web-server",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun build --target bun --compile index.ts --outfile dist/server.exe",
    "start": "bun run dist/index.js",
    "dev": "bun run --watch index.ts"
  },
  "dependencies": {
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/express": "^5.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
