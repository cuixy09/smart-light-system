{
  "name": "our-first-project",
  "private": true,
  "workspaces": ["packages/web", "packages/web-server"],
  "scripts": {
    "dev": "bun run --cwd '*' dev",
    "dev:web": "bun run --cwd packages/web dev",
    "dev:server": "bun run --cwd packages/web-server dev",
    "build:web": "bun run --cwd packages/web build",
    "build:server": "bun run --cwd packages/web-server build",
    "build": "bun run build:web && bun run build:server",
    "start:server": "bun run --cwd packages/web-server start",
    "start:server:exe": "bun run --cwd packages/web-server start:exe"
  }
}
