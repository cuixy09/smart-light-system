{
  "name": "web-server",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun build --target bun --minify --sourcemap --bytecode --compile index.ts --outfile dist/server.exe",
    "start": "bun index.ts",
    "start:exe": "dist/server.exe",
    "dev": "bun run --watch index.ts"
  },
  "dependencies": {
    "express": "5.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/express": "^5.0.0",
    "typescript": "~6.0.0"
  }
}
